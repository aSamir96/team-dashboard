/* ===================== aggregation ===================== */
function memberAgg(data, memberId, month) {
  const recs = data.kpis.filter((k) => k.memberId === memberId && k.month === month);
  const sum = (f) => recs.reduce((a, r) => a + (Number(r[f]) || 0), 0);
  const avg = (f) => (recs.length ? sum(f) / recs.length : 0);
  return { posts: sum("posts"), content: sum("content"), reach: sum("reach"), followers: sum("followers"), engagement: avg("engagement"), onTime: avg("onTime"), count: recs.length };
}
function teamScores(data, month) {
  const aggs = data.members.map((m) => ({ member: m, ...memberAgg(data, m.id, month) }));
  const maxOf = (f) => Math.max(1, ...aggs.map((a) => a[f]));
  const maxes = { posts: maxOf("posts"), content: maxOf("content"), engagement: maxOf("engagement"), reach: maxOf("reach"), followers: maxOf("followers"), onTime: maxOf("onTime") };
  return aggs.map((a) => {
    const norm = METRICS.map((mt) => (a[mt.key] / maxes[mt.key]) * 100);
    const score = a.count ? Math.round(norm.reduce((x, y) => x + y, 0) / norm.length) : 0;
    return { ...a, score };
  }).sort((x, y) => y.score - x.score);
}

