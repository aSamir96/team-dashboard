/* ===================== SVG charts ===================== */
function LineDual({ data, series, height = 230 }) {
  if (!data.length) return null;
  const W = 620, H = height, P = { l: 26, r: 16, t: 16, b: 26 };
  const iw = W - P.l - P.r, ih = H - P.t - P.b;
  const x = (i) => (data.length === 1 ? P.l + iw / 2 : P.l + i * iw / (data.length - 1));
  return (
    <svg viewBox={`0 0 ${W} ${H}`} width="100%" preserveAspectRatio="xMidYMid meet" style={{ display: "block" }}>
      {[0, .25, .5, .75, 1].map((t, i) => <line key={i} x1={P.l} x2={W - P.r} y1={P.t + ih * t} y2={P.t + ih * t} stroke={C.line} />)}
      {series.map((s) => {
        const max = Math.max(1, ...data.map((d) => +d[s.k] || 0));
        const pts = data.map((d, i) => `${x(i)},${P.t + ih - ((+d[s.k] || 0) / max) * ih}`).join(" ");
        return <polyline key={s.k} points={pts} fill="none" stroke={s.color} strokeWidth="3" strokeLinejoin="round" strokeLinecap="round" />;
      })}
      {series.map((s) => {
        const max = Math.max(1, ...data.map((d) => +d[s.k] || 0));
        return data.map((d, i) => (
          <circle key={s.k + i} cx={x(i)} cy={P.t + ih - ((+d[s.k] || 0) / max) * ih} r="3.5" fill={s.color}>
            <title>{`${d.name} — ${s.label}: ${d[s.k]}`}</title>
          </circle>
        ));
      })}
      {data.map((d, i) => <text key={i} x={x(i)} y={H - 8} fontSize="12" fill={C.inkSoft} textAnchor="middle" fontFamily="Cairo">{d.name}</text>)}
    </svg>
  );
}
function Bars({ data, series, height = 250 }) {
  if (!data.length) return null;
  const W = 640, H = height, P = { l: 14, r: 14, t: 24, b: 30 };
  const iw = W - P.l - P.r, ih = H - P.t - P.b, gW = iw / data.length;
  const bw = Math.min(26, (gW - 18) / series.length);
  const maxes = {}; series.forEach((s) => (maxes[s.k] = Math.max(1, ...data.map((d) => +d[s.k] || 0))));
  return (
    <svg viewBox={`0 0 ${W} ${H}`} width="100%" preserveAspectRatio="xMidYMid meet" style={{ display: "block" }}>
      <line x1={P.l} x2={W - P.r} y1={P.t + ih} y2={P.t + ih} stroke={C.line} />
      {data.map((d, gi) => {
        const gx = P.l + gi * gW + gW / 2;
        const span = series.length * bw + (series.length - 1) * 6;
        return (
          <g key={gi}>
            {series.map((s, si) => {
              const v = +d[s.k] || 0, hgt = (v / maxes[s.k]) * ih, bx = gx - span / 2 + si * (bw + 6);
              return (
                <g key={s.k}>
                  <rect x={bx} y={P.t + ih - hgt} width={bw} height={hgt} rx="5" fill={s.color} />
                  <text x={bx + bw / 2} y={P.t + ih - hgt - 5} fontSize="11" fill={C.ink} textAnchor="middle" fontFamily="Cairo">{v}</text>
                </g>
              );
            })}
            <text x={gx} y={H - 10} fontSize="12" fill={C.inkSoft} textAnchor="middle" fontFamily="Cairo">{d.name}</text>
          </g>
        );
      })}
    </svg>
  );
}
function arc(cx, cy, r, ri, a0, a1) {
  const p = (rr, a) => [cx + rr * Math.cos(a), cy + rr * Math.sin(a)];
  const large = a1 - a0 > Math.PI ? 1 : 0;
  const [x0, y0] = p(r, a0), [x1, y1] = p(r, a1), [x2, y2] = p(ri, a1), [x3, y3] = p(ri, a0);
  return `M${x0} ${y0} A${r} ${r} 0 ${large} 1 ${x1} ${y1} L${x2} ${y2} A${ri} ${ri} 0 ${large} 0 ${x3} ${y3} Z`;
}
function Donut({ data, size = 200 }) {
  const total = data.reduce((a, d) => a + d.value, 0);
  if (!total) return null;
  const cx = size / 2, cy = size / 2, r = size / 2 - 6, ri = r * 0.6;
  if (data.length === 1) {
    return (
      <svg viewBox={`0 0 ${size} ${size}`} width="100%" style={{ maxHeight: 230, display: "block" }}>
        <circle cx={cx} cy={cy} r={(r + ri) / 2} fill="none" stroke={data[0].color} strokeWidth={r - ri}>
          <title>{`${data[0].name}: ${data[0].value}`}</title>
        </circle>
      </svg>
    );
  }
  let a = -Math.PI / 2;
  return (
    <svg viewBox={`0 0 ${size} ${size}`} width="100%" style={{ maxHeight: 230, display: "block" }}>
      {data.map((d, i) => {
        const ang = (d.value / total) * Math.PI * 2, a0 = a; a += ang;
        return <path key={i} d={arc(cx, cy, r, ri, a0, a0 + ang)} fill={d.color}><title>{`${d.name}: ${d.value}`}</title></path>;
      })}
    </svg>
  );
}

