/* ===================== Dashboard ===================== */
function Dashboard({ data, month, setMonth, update, setTab }) {
  const months = useMemo(() => { const s = new Set(data.kpis.map((k) => k.month)); s.add(nowMonth()); return [...s].sort().reverse(); }, [data.kpis]);
  const totals = useMemo(() => {
    const recs = data.kpis.filter((k) => k.month === month);
    const sum = (f) => recs.reduce((a, r) => a + (Number(r[f]) || 0), 0);
    const eng = recs.length ? recs.reduce((a, r) => a + (Number(r.engagement) || 0), 0) / recs.length : 0;
    return { posts: sum("posts"), reach: sum("reach"), followers: sum("followers"), engagement: eng };
  }, [data.kpis, month]);
  const byPlatform = useMemo(() => {
    const map = {};
    data.kpis.filter((k) => k.month === month).forEach((k) => { const p = data.projects.find((x) => x.id === k.projectId); const key = p ? p.platform : "other"; map[key] = (map[key] || 0) + (Number(k.posts) || 0); });
    return Object.entries(map).map(([k, v]) => ({ name: PLATFORMS[k]?.label || k, value: v, color: PLATFORMS[k]?.color || C.inkSoft }));
  }, [data, month]);
  const scores = useMemo(() => teamScores(data, month), [data, month]);
  const top = scores.filter((s) => s.count > 0).slice(0, 5);
  const trend = useMemo(() => {
    const last6 = [...months].slice(0, 6).reverse();
    return last6.map((m) => { const recs = data.kpis.filter((k) => k.month === m); const eng = recs.length ? recs.reduce((a, r) => a + (+r.engagement || 0), 0) / recs.length : 0; return { name: monthLabel(m).split(" ")[0], posts: recs.reduce((a, r) => a + (+r.posts || 0), 0), eng: +eng.toFixed(1) }; });
  }, [data.kpis, months]);
  const isEmpty = !data.projects.length && !data.members.length;

  const stat = (label, value, icon, color) => (
    <Card style={{ display: "flex", alignItems: "center", gap: 14 }}>
      <div style={{ width: 46, height: 46, borderRadius: 13, background: color + "18", color, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}><Icon name={icon} size={22} /></div>
      <div><div style={{ fontSize: 24, fontWeight: 800, lineHeight: 1.1 }}>{value}</div><div style={{ fontSize: 13, color: C.inkSoft }}>{label}</div></div>
    </Card>
  );

  return (
    <div>
      <Header title="لوحة التحكم" sub="كل أرقام الفريق في مكان واحد" right={<MonthPicker months={months} month={month} setMonth={setMonth} />} />
      {isEmpty ? (
        <Card><Empty icon="sparkles" title="ابدأ ببناء مساحتك" sub="ضيف مشاريعك وفريقك، أو جرّب ببيانات جاهزة عشان تشوف الشكل."
          action={<div style={{ display: "flex", gap: 10, justifyContent: "center", flexWrap: "wrap" }}>
            <Btn onClick={() => update(sampleData())}><Icon name="sparkles" size={16} /> تجربة ببيانات جاهزة</Btn>
            <Btn kind="line" onClick={() => setTab("projects")}><Icon name="plus" size={16} /> ضيف أول مشروع</Btn>
          </div>} /></Card>
      ) : (
        <>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(170px, 1fr))", gap: 14, marginBottom: 16 }}>
            {stat("أفراد الفريق", fmt(data.members.length), "users", C.primary)}
            {stat("مشاريع / حسابات", fmt(data.projects.length), "folder", C.rose)}
            {stat("منشورات الشهر", fmt(totals.posts), "file", C.amber)}
            {stat("متوسط التفاعل", totals.engagement.toFixed(1) + "%", "heart", C.green)}
            {stat("نمو المتابعين", fmt(totals.followers), "userplus", "#8254E5")}
          </div>
          <div style={{ display: "grid", gridTemplateColumns: "1.4fr 1fr", gap: 16, marginBottom: 16 }}>
            <Card>
              <CardTitle>المنشورات والتفاعل (اتجاه نسبي)</CardTitle>
              <LineDual data={trend} series={[{ k: "posts", color: C.primary, label: "منشورات" }, { k: "eng", color: C.green, label: "تفاعل %" }]} />
              <Legend items={[{ color: C.primary, label: "منشورات" }, { color: C.green, label: "تفاعل %" }]} />
            </Card>
            <Card>
              <CardTitle>المنشورات حسب المنصّة</CardTitle>
              {byPlatform.length ? <Donut data={byPlatform} /> : <Empty icon="file" title="لا توجد بيانات" sub="سجّل KPIs للشهر ده." />}
              <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginTop: 10, justifyContent: "center" }}>
                {byPlatform.map((e, i) => <Pill key={i} color={e.color}>{e.name} · {fmt(e.value)}</Pill>)}
              </div>
            </Card>
          </div>
          <Card>
            <CardTitle>أفضل أداء — {monthLabel(month)}</CardTitle>
            {top.length ? (
              <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                {top.map((s, i) => (
                  <div key={s.member.id} style={{ display: "flex", alignItems: "center", gap: 14, padding: "10px 12px", borderRadius: 12, background: i === 0 ? "#FFF8E9" : C.bg }}>
                    <div style={{ width: 30, height: 30, borderRadius: 9, background: i === 0 ? C.amber : "#fff", border: `1px solid ${C.line}`, color: i === 0 ? "#fff" : C.inkSoft, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 800, fontSize: 14, flexShrink: 0 }}>{i + 1}</div>
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{ fontWeight: 800 }}>{s.member.name}</div>
                      <div style={{ fontSize: 12, color: C.inkSoft }}>{ROLES[s.member.role]} · {s.count} حساب · {fmt(s.posts)} منشور · {s.engagement.toFixed(1)}% تفاعل</div>
                    </div>
                    <div style={{ width: 120, height: 8, borderRadius: 999, background: C.line, overflow: "hidden" }}><div style={{ width: `${s.score}%`, height: "100%", background: C.primary }} /></div>
                    <div style={{ fontWeight: 800, color: C.primary, width: 36, textAlign: "left" }}>{s.score}</div>
                  </div>
                ))}
              </div>
            ) : <Empty icon="award" title="لا يوجد أداء مسجّل" sub="روح تبويب الأداء وسجّل أرقام الشهر." />}
            <div style={{ fontSize: 11.5, color: C.inkSoft, marginTop: 10 }}>نقاط الأداء = متوسط ترتيب الفرد نسبةً لأعلى أداء في الفريق في كل مقياس (٠–١٠٠).</div>
          </Card>
        </>
      )}
    </div>
  );
}

