      )}
      {scores.some((s) => s.count > 0) && (
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(260px,1fr))", gap: 14, marginBottom: 16 }}>
          {scores.filter((s) => s.count > 0).map((s) => (
            <Card key={s.member.id}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
                <div style={{ fontWeight: 800, fontSize: 16 }}>{s.member.name}</div>
                <div style={{ fontWeight: 800, color: C.primary, fontSize: 20 }}>{s.score}</div>
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                <Mini label="منشورات" v={fmt(s.posts)} /><Mini label="محتوى" v={fmt(s.content)} />
                <Mini label="تفاعل" v={s.engagement.toFixed(1) + "%"} /><Mini label="وصول" v={fmt(s.reach)} />
                <Mini label="متابعين +" v={fmt(s.followers)} /><Mini label="التزام" v={s.onTime.toFixed(0) + "%"} />
              </div>
            </Card>
          ))}
        </div>
      )}
      <Card>
        <CardTitle>سجلّات {monthLabel(month)}</CardTitle>
        {recs.length === 0 ? (
          <Empty icon="trending" title="مفيش أرقام للشهر ده" sub={canAdd ? "اضغط «تسجيل أداء» وابدأ تدخل أرقام الفريق." : "ضيف فريق ومشاريع الأول."} action={canAdd ? <Btn onClick={() => setModal({ new: true })}><Icon name="plus" size={16} /> تسجيل أداء</Btn> : null} />
        ) : (
          <div style={{ overflowX: "auto" }}>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13.5, minWidth: 720 }}>
              <thead><tr style={{ color: C.inkSoft, textAlign: "right" }}>
                {["الفرد", "الحساب", "منشورات", "محتوى", "تفاعل %", "وصول", "متابعين +", "التزام %", ""].map((h, i) => <th key={i} style={{ padding: "8px 10px", fontWeight: 700, borderBottom: `1px solid ${C.line}`, whiteSpace: "nowrap" }}>{h}</th>)}
              </tr></thead>
              <tbody>
                {recs.map((k) => {
                  const m = data.members.find((x) => x.id === k.memberId); const p = data.projects.find((x) => x.id === k.projectId); const pl = p ? PLATFORMS[p.platform] : null;
                  return (
                    <tr key={k.id} style={{ borderBottom: `1px solid ${C.line}` }}>
                      <td style={{ padding: "10px", fontWeight: 700 }}>{m ? m.name : "—"}</td>
                      <td style={{ padding: "10px" }}>{p ? <Pill color={pl.color}>{p.name}</Pill> : "—"}</td>
                      <td style={{ padding: "10px" }}>{fmt(k.posts)}</td><td style={{ padding: "10px" }}>{fmt(k.content)}</td>
                      <td style={{ padding: "10px" }}>{k.engagement}%</td><td style={{ padding: "10px" }}>{fmt(k.reach)}</td>
                      <td style={{ padding: "10px" }}>{fmt(k.followers)}</td><td style={{ padding: "10px" }}>{k.onTime}%</td>
                      <td style={{ padding: "10px" }}><div style={{ display: "flex", gap: 4 }}><IconBtn onClick={() => setModal({ ...k })}><Icon name="pencil" size={14} /></IconBtn><IconBtn danger onClick={() => removeKpi(k.id)}><Icon name="trash" size={14} /></IconBtn></div></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </Card>
      {modal && <KpiForm initial={modal.new ? null : modal} data={data} month={month} onSave={saveKpi} onClose={() => setModal(null)} />}
    </div>
  );
}
function Mini({ label, v }) {
  return <div style={{ background: C.bg, borderRadius: 10, padding: "8px 10px" }}><div style={{ fontSize: 11.5, color: C.inkSoft }}>{label}</div><div style={{ fontWeight: 800, fontSize: 15 }}>{v}</div></div>;
}
function KpiForm({ initial, data, month, onSave, onClose }) {
  const [f, setF] = useState(initial || { id: uid(), memberId: data.members[0]?.id || "", projectId: "", month, posts: "", content: "", engagement: "", reach: "", followers: "", onTime: "" });
  const set = (k, v) => setF((p) => ({ ...p, [k]: v }));
  const assigned = data.assignments.filter((a) => a.memberId === f.memberId).map((a) => a.projectId);
  const projOptions = data.projects.filter((p) => (assigned.length ? assigned.includes(p.id) : true));
  useEffect(() => { if (!projOptions.find((p) => p.id === f.projectId)) set("projectId", projOptions[0]?.id || ""); }, [f.memberId]);
  const num = (k, label) => <Field label={label}><input type="number" step="any" min="0" style={inputStyle} value={f[k]} onChange={(e) => set(k, e.target.value === "" ? "" : Number(e.target.value))} placeholder="0" /></Field>;
  return (
    <Modal title={initial ? "تعديل الأداء" : "تسجيل أداء"} onClose={onClose}>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
        <Field label="الفرد *"><select style={inputStyle} value={f.memberId} onChange={(e) => set("memberId", e.target.value)}>{data.members.map((m) => <option key={m.id} value={m.id}>{m.name}</option>)}</select></Field>
        <Field label="الحساب / المشروع *"><select style={inputStyle} value={f.projectId} onChange={(e) => set("projectId", e.target.value)}><option value="">— اختر —</option>{projOptions.map((p) => <option key={p.id} value={p.id}>{p.name}</option>)}</select></Field>
      </div>
      <Field label="الشهر"><input type="month" style={inputStyle} value={f.month} onChange={(e) => set("month", e.target.value)} /></Field>
      <div style={{ height: 1, background: C.line, margin: "4px 0 14px" }} />
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
        {num("posts", "عدد المنشورات")}{num("content", "المحتوى المنتج")}{num("engagement", "معدل التفاعل %")}
        {num("reach", "الوصول / الانطباعات")}{num("followers", "نمو المتابعين")}{num("onTime", "الالتزام بالمواعيد %")}
      </div>
      <div style={{ display: "flex", gap: 10, marginTop: 6 }}><Btn onClick={() => f.memberId && f.projectId && onSave(f)}>حفظ</Btn><Btn kind="line" onClick={onClose}>إلغاء</Btn></div>
    </Modal>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
